---
import PostHog from '../components/posthog.astro';
import { PrivacyBanner } from '../components/features/privacy/PrivacyBanner';
import { Header } from '../components/ui/Header';
import { getCollection, render } from 'astro:content';
import { ViewTransitions } from 'astro:transitions';

const topCuts = [0, 6, 0, 5, 0, 4];
const bottomCuts = [8, 3, 7, 4, 6, 2];

function getClipPath(projectIndex: number, shotIndex: number): string {
  const offsetIndex = (projectIndex * 5 + shotIndex) % bottomCuts.length;
  const topCut = topCuts[offsetIndex];
  const bottomCut = bottomCuts[offsetIndex];

  if (shotIndex % 2 === 0) {
    return `polygon(0% 0%, 100% 0%, ${100 - bottomCut}% 100%, 0% 100%)`;
  }

  return `polygon(0% 0%, ${100 - topCut}% 0%, 100% 100%, ${bottomCut}% 100%)`;
}

const curatedProjects = (await getCollection('projects'))
  .filter((entry) => entry.data.featuredInRecentProjects && (entry.data.gallery?.length ?? 0) > 0)
  .sort((a, b) => (a.data.recentProjectsOrder ?? Number.MAX_SAFE_INTEGER) - (b.data.recentProjectsOrder ?? Number.MAX_SAFE_INTEGER));

const renderedProjects = await Promise.all(
  curatedProjects.map(async (project, projectIndex) => {
    const { Content } = await render(project);

    return {
      ...project,
      Content,
      projectIndex,
      gallery: project.data.gallery ?? [],
    };
  }),
);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600;700&family=Newsreader:ital,wght@0,400;0,500;1,400&display=swap"
      rel="stylesheet"
    />
    <title>Recent Projects — Jaan Sokk</title>
    <meta
      name="description"
      content="A curated recent-projects view built from real project notes, product screenshots, and implementation details."
    />
    <ViewTransitions />
    <PostHog />
  </head>
  <body>
    <PrivacyBanner client:load />
    <div class="v2-concept min-h-screen relative">
      <div class="fixed inset-0 z-0">
        <div
          class="absolute inset-0 bg-cover bg-center opacity-40"
          style="background-image: url('/20221211-SBW_0367.jpg');"
        ></div>
        <div class="absolute inset-0 bg-gradient-to-b from-[#0a0a0a] via-[#0a0a0a]/72 to-[#0a0a0a]"></div>
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(164,198,190,0.06)_0%,transparent_62%)]"></div>
      </div>

      <Header activePage="projects" client:load />

      <main class="relative z-10 max-w-6xl mx-auto px-6 pt-24 pb-24 md:pb-32">
        <section class="mb-14 md:mb-18">
          <p class="text-xs uppercase tracking-[0.18em] text-[var(--v2-accent)] mb-4">Recent Projects</p>
          <h1 class="max-w-4xl text-4xl md:text-5xl lg:text-6xl font-medium leading-[1.05] tracking-[-0.03em] text-[var(--v2-text)]">
            Curated work with the
            <span class="v2-serif text-[var(--v2-accent)]">proof still visible</span>.
          </h1>
          <p class="mt-6 max-w-2xl text-base md:text-lg leading-8 text-[var(--v2-text-secondary)]">
            A focused reading path through selected projects: company, context, implementation notes,
            and the product surfaces themselves.
          </p>
        </section>

        {renderedProjects.length > 0 ? (
          <div class="space-y-20 md:space-y-28">
            {renderedProjects.map((project) => {
              const Content = project.Content;

              return (
                <section class="project-row grid gap-10 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:gap-14">
                  <div class="lg:sticky lg:top-24 lg:self-start">
                    <p class="text-xs uppercase tracking-[0.16em] text-[var(--v2-accent)]">
                      {project.data.company}
                    </p>
                    <h2 class="mt-3 text-3xl md:text-4xl lg:text-5xl font-medium leading-[1.05] tracking-[-0.03em] text-[var(--v2-text)]">
                      {project.data.title}
                    </h2>

                    <div class="mt-5 flex flex-wrap gap-2">
                      {project.data.tags.map((tag) => (
                        <span class="rounded-full border border-[var(--v2-border)] bg-black/15 px-3 py-1 text-xs text-[var(--v2-text-secondary)]">
                          {tag}
                        </span>
                      ))}
                    </div>

                    <div class="project-body mt-8">
                      <Content />
                    </div>
                  </div>

                  <div class="space-y-5 md:space-y-7">
                    {project.gallery.map((imageSrc, shotIndex) => {
                      const clipPath = getClipPath(project.projectIndex, shotIndex);
                      const offsetClass = shotIndex % 2 === 0 ? 'md:mr-14 lg:mr-18' : 'md:ml-14 lg:ml-18';

                      return (
                        <div class:list={['shot-wrap', offsetClass]}>
                          <img
                            src={imageSrc}
                            alt={`${project.data.title} screenshot ${shotIndex + 1}`}
                            loading="lazy"
                            class="shot-image"
                            style={`clip-path: ${clipPath};`}
                          />
                        </div>
                      );
                    })}
                  </div>
                </section>
              );
            })}
          </div>
        ) : (
          <section class="rounded-[28px] border border-[var(--v2-border)] bg-black/15 px-6 py-8">
            <p class="text-sm leading-7 text-[var(--v2-text-secondary)]">
              No projects are currently featured here. Add `featuredInRecentProjects: true`,
              `recentProjectsOrder`, and `gallery[]` to a project entry to publish it on this page.
            </p>
          </section>
        )}
      </main>
    </div>
  </body>
</html>

<style is:global>
  @tailwind base;
  @tailwind components;
  @tailwind utilities;

  :root {
    --v2-bg: #0a0a0a;
    --v2-bg-elevated: #141414;
    --v2-bg-elevated-rgb: 20 20 20;
    --v2-bg-card: #1a1a1a;
    --v2-text: #e6e6e6;
    --v2-text-secondary: #9f9f9f;
    --v2-text-tertiary: #616161;
    --v2-accent: #a4c6be;
    --v2-accent-dim: rgba(164, 198, 190, 0.15);
    --v2-border: #2a2a2a;
    --v2-border-subtle: #1e1e1e;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    background: var(--v2-bg);
    color: var(--v2-text);
    line-height: 1.6;
  }

  .v2-concept {
    font-family: 'Instrument Sans', -apple-system, BlinkMacSystemFont, sans-serif;
    background: var(--v2-bg);
    color: var(--v2-text);
    min-height: 100vh;
  }

  .v2-serif {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
  }

  .project-row + .project-row {
    padding-top: 0.25rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .project-body {
    color: var(--v2-text-secondary);
  }

  .project-body :global(*) + * {
    margin-top: 1rem;
  }

  .project-body :global(h2) {
    margin-top: 2rem;
    color: var(--v2-text);
    font-size: 0.85rem;
    line-height: 1.4;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-weight: 600;
  }

  .project-body :global(h3) {
    margin-top: 1.5rem;
    color: var(--v2-text);
    font-size: 1.05rem;
    line-height: 1.4;
    font-weight: 600;
  }

  .project-body :global(p) {
    max-width: 62ch;
    line-height: 1.9;
  }

  .project-body :global(ul) {
    padding-left: 0;
    list-style: none;
  }

  .project-body :global(li) {
    position: relative;
    padding-left: 1.1rem;
    line-height: 1.85;
  }

  .project-body :global(li)::before {
    content: '•';
    position: absolute;
    left: 0;
    top: 0;
    color: var(--v2-accent);
  }

  .project-body :global(strong) {
    color: var(--v2-text);
    font-weight: 600;
  }

  .project-body :global(a) {
    color: var(--v2-accent);
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .project-body :global(a:hover) {
    color: var(--v2-text);
  }

  .project-body :global(code) {
    color: var(--v2-text);
    font-size: 0.92em;
  }

  .shot-wrap {
    position: relative;
  }

  .shot-image {
    display: block;
    width: 100%;
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 24px 54px rgba(0, 0, 0, 0.28);
    background: rgba(10, 10, 10, 0.65);
  }

  @media (max-width: 1023px) {
    .project-row + .project-row {
      padding-top: 0;
      border-top: none;
    }
  }
</style>
