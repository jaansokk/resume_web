---
interface Props {
  title: string;
  description: string;
  path?: string;
  imagePath?: string;
  type?: string;
}

const {
  title,
  description,
  path = Astro.url.pathname,
  imagePath = '/social-preview.png',
  type = 'website',
} = Astro.props;

const site = Astro.site ?? new URL('https://jaan.sokkphoto.com');
const canonicalUrl = new URL(path, site).toString();
const imageUrl = new URL(imagePath, site).toString();
const imageAlt = 'Screenshot of Jaan Sokk interactive resume website';
---

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />

<meta property="og:type" content={type} />
<meta property="og:site_name" content="Jaan Sokk" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:image" content={imageUrl} />
<meta property="og:image:secure_url" content={imageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={imageAlt} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageUrl} />
<meta name="twitter:image:alt" content={imageAlt} />
